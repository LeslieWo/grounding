# 复制成 .env 再填。.env 永远不进仓库。

# ===== LLM 供应商（任选一个 OpenAI 兼容的接口）=====
# A. OpenAI
OPENAI_API_KEY=sk-你的key
OPENAI_BASE_URL=
GROUNDING_MODEL=gpt-4o
INGEST_MODEL=gpt-4o
STRUCT_METHOD=function_calling
DISABLE_THINKING=0

# B. z.ai 的 GLM（把上面注释掉，用这组）
# OPENAI_API_KEY=你的z.ai的key
# OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
# GROUNDING_MODEL=glm-4.6
# INGEST_MODEL=glm-4.5v
# STRUCT_METHOD=function_calling
# DISABLE_THINKING=1      # ⚠️ GLM 默认开"深度思考"，一句话要 20-35 秒；关掉只要 ~2 秒

# C. 本地 Ollama（离线，但小模型质量明显差）
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# GROUNDING_MODEL=qwen2.5vl:32b
# INGEST_MODEL=qwen2.5vl:7b
# STRUCT_METHOD=json_schema   # 本地视觉模型不支持 tools，只能用 json_schema

# ===== 客户端门禁 =====
# 手机 app 调这个后端时要带的 key（自己随便生成一串长的随机字符串）。
GROUNDING_API_KEY=
# 本地开发想免 key 就设 0；线上必须是 1。
REQUIRE_API_KEY=0
